{
  "name": "minecraft-render-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Automated render pipeline producing transparent-background headshots and spin animations for every Minecraft Bedrock mob.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "mrp": "./cli.js"
  },
  "scripts": {
    "fetch-version": "node scripts/fetch-version.js",
    "extract-pack": "node scripts/extract-pack.js",
    "diff-entities": "node scripts/diff-entities.js",
    "parse-geometry": "node scripts/parse-geometry.js",
    "capture": "node render/capture.js",
    "render": "node cli.js",
    "render:force-all": "node cli.js --force-all",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "gif-encoder-2": "^1.0.5",
    "puppeteer": "^23.5.0",
    "sharp": "^0.33.5",
    "tga": "^1.0.7",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3"
  }
}
